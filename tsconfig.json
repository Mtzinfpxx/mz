{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "lib": ["ES2020"],
    "types": ["node"],

    "rootDir": "./backend/src",
    "outDir": "./backend/dist",

    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    "declaration": true,
    "sourceMap": true
  },

  "include": ["backend/src/**/*.ts"],
  "exclude": ["node_modules", "backend/dist"]
}